{
  "_notes": [
    "Config filled for The Shimazu Clan custom civilization under Shimazu Yoshihiro.",
    "Unzip Shimazu_Pipeline_Package.zip into the PNGtoDDSConverter repo root so files land under ./Input/Shimazu/.",
    "PowerShell check: py -3 .\\universal_civ5_pipeline_spartan_artfix_v9.py --config .\\Shimazu_civ_creation_template.json --check-only",
    "PowerShell build: py -3 .\\universal_civ5_pipeline_spartan_artfix_v9.py --config .\\Shimazu_civ_creation_template.json",
    "Default preset is no-mod-integration so DDS/previews can be generated before the final mod folder exists.",
    "After the Shimazu mod folder exists, set preset to existing-combined-atlas, set mod_data_dir, then run --write-mod.",
    "Normal icons use the Civ V circular icon profile with safe_subject_scale 0.65625.",
    "Alpha and unit flags use black-to-transparent glyph profiles; filenames intentionally include _black.",
    "Leader scene source is widescreen; Civ V final leader-scene DDS should still be produced through the leader scene crop/profile used by the pipeline."
  ],
  "prefix": "Shimazu",
  "input_dir": "./Input/Shimazu",
  "output_dir": "./Output/Shimazu",
  "mod_data_dir": "",
  "civ_icon": "./Input/Shimazu/Shimazu_CivilizationIcon.png",
  "leader_icon": "./Input/Shimazu/ShimazuYoshihiro_LeaderIcon.png",
  "alpha_icon": "./Input/Shimazu/Shimazu_AlphaIcon_black.png",
  "default_profile": "civ5_circular_icon",
  "normal_icon_profile": "civ5_circular_icon",
  "support_icon_profile": "civ5_circular_icon",
  "alpha_profile": "civ5_alpha_glyph_black_to_transparent",
  "unit_flag_profile": "civ5_unit_flag_black_to_transparent",
  "icon_fit_policy": "contain",
  "write_per_asset_previews": true,
  "allow_numeric_suffixes": false,
